{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
    {
        "name": "Attach",
        "port": 9229,
        "request": "attach",
        "skipFiles": [
            "<node_internals>/**"
        ],
        "type": "node"
    },
    {
        "type": "node",
        "request": "launch",
        "name": "Debug Backend (ts-node)",
        "preLaunchTask": "ssh-postgres-tunnel",
        "runtimeArgs": [
            "-r",
            "ts-node/register"
        ],
        "program": "${workspaceFolder}/backend/index.ts",
        "cwd": "${workspaceFolder}/backend",
        "outFiles": ["${workspaceFolder}/backend/**/*.js"],
        "env": {
            "TS_NODE_PROJECT": "${workspaceFolder}/backend/tsconfig.json"
        },
        "skipFiles": ["<node_internals>/**"]
    },
    {
        "type": "node",
        "request": "launch",
        "name": "Debug Backend (compiled)",
        "preLaunchTask": "ssh-postgres-tunnel",
        "program": "${workspaceFolder}/backend/dist/index.js",
        "cwd": "${workspaceFolder}/backend",
        "preLaunchTask": "build-backend",
        "outFiles": ["${workspaceFolder}/backend/dist/**/*.js"],
        "skipFiles": ["<node_internals>/**"]
    }
    ]
}