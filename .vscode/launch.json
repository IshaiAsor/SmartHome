{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
    {
        "name": "Debug Backend (dev + hot reload)",
        "type": "node",
        "request": "attach",
        "port": 9229,
        "restart": true,
        "preLaunchTask": "start-backend-debug",
        "skipFiles": ["<node_internals>/**"],
        "sourceMaps": true,
        "outFiles": ["${workspaceFolder:Backend API}/**/*.js"]
    },
    {
        "name": "Start SSH Tunnel",
        "type": "node",
        "request": "launch",
        "preLaunchTask": "ssh-postgres-tunnel",
        "runtimeExecutable": "node",
        "runtimeArgs": [
            "-e",
            "console.log('✅ SSH tunnel task started in the background.');"
        ]
    },
    {
        "type": "node",
        "request": "launch",
        "name": "Debug DB Seed (ts-node)",
        "runtimeArgs": [
            "-r",
            "ts-node/register"
        ],
        "program": "${workspaceFolder:Prisma}/seed.ts",
        "cwd": "${workspaceFolder:Prisma}",
        "outFiles": ["${workspaceFolder:Prisma}/**/*.js"],
        "envFile": "${workspaceFolder:Project Root}/.env",
        "env": {
            "TS_NODE_PROJECT": "${workspaceFolder:Prisma}/tsconfig.json"
        },
        "skipFiles": ["<node_internals>/**"]
    },
    {
        "type": "node",
        "request": "launch",
        "name": "Catalog: Generate Manifests",
        "runtimeExecutable": "node",
        "program": "${workspaceFolder:ESP32 Firmware}/tools/generate-manifests.mjs",
        "cwd": "${workspaceFolder:Prisma}",
        "skipFiles": ["<node_internals>/**"],
        "presentation": { "group": "catalog" }
    },
    {
        "type": "node",
        "request": "launch",
        "name": "Catalog: Seed DB",
        "runtimeArgs": [
            "-r",
            "ts-node/register"
        ],
        "program": "${workspaceFolder:Prisma}/seed-catalog.ts",
        "cwd": "${workspaceFolder:Prisma}",
        "outFiles": ["${workspaceFolder:Prisma}/**/*.js"],
        "envFile": "${workspaceFolder:Project Root}/.env",
        "env": {
            "TS_NODE_PROJECT": "${workspaceFolder:Prisma}/tsconfig.json"
        },
        "preLaunchTask": "catalog:gen",
        "skipFiles": ["<node_internals>/**"],
        "presentation": { "group": "catalog" }
    },
    {
        "type": "node",
        "request": "launch",
        "name": "Debug Backend (ts-node)",
        "runtimeArgs": [
            "-r",
            "ts-node/register"
        ],
        "program": "${workspaceFolder:Backend API}/index.ts",
        "cwd": "${workspaceFolder:Backend API}",
        "outFiles": ["${workspaceFolder:Backend API}/**/*.js"],
        "envFile": "${workspaceFolder:Project Root}/.env",
        "env": {
            "TS_NODE_PROJECT": "${workspaceFolder:Backend API}/tsconfig.json"
        },
        "skipFiles": ["<node_internals>/**"]
    },
    {
        "type": "node",
        "request": "launch",
        "name": "Debug Backend (compiled)",
        "program": "${workspaceFolder:Backend API}/dist/index.js",
        "cwd": "${workspaceFolder:Backend API}",
        "preLaunchTask": "pre-debug-compiled",
        "outFiles": ["${workspaceFolder:Backend API}/dist/**/*.js"],
        "skipFiles": ["<node_internals>/**"]
    },
    {
        "name": "Debug FrontEnd (Chrome)",
        "type": "pwa-chrome",
        "request": "launch",
        "url": "http://localhost:4200",
        "webRoot": "${workspaceFolder:Backoffice UI}",
        "preLaunchTask": "serve-backoffice"
    },
    {
        "type": "platformio-debug",
        "request": "launch",
        "name": "ESP32: PIO Debug (test)",
        "executable": "${workspaceFolder:ESP32 Firmware}/.pio/build/4d_systems_esp32s3_gen4_r8n16-test/firmware.elf",
        "projectEnvName": "4d_systems_esp32s3_gen4_r8n16-test",
        "projectDir": "${workspaceFolder:ESP32 Firmware}",
        "cwd": "${workspaceFolder:ESP32 Firmware}",
        "preLaunchTask": "PlatformIO: Build (ESP32Code)",
        "internalConsoleOptions": "openOnSessionStart"
    },
    {
        "name": "Debug ML Router (dev + hot reload)",
        "type": "node",
        "request": "launch",
        "cwd": "${workspaceFolder:Project Root}",
        "runtimeExecutable": "npx",
        "runtimeArgs": [
            "@dotenvx/dotenvx", "run", "--",
            "npx", "nodemon",
            "--cwd", "services/ml-router",
            "--exec", "node -r ts-node/register",
            "--ext", "ts,json",
            "src/index.ts"
        ],
        "env": { "TS_NODE_PROJECT": "tsconfig.json", "PORT": "3002" },
        "console": "internalConsole",
        "outputCapture": "std",
        "autoAttachChildProcesses": true,
        "restart": true,
        "preLaunchTask": "prep-ml-router",
        "skipFiles": ["<node_internals>/**"],
        "sourceMaps": true,
        "outFiles": ["${workspaceFolder:ML Router}/**/*.js"]
    },
    {
        "name": "Debug Device Gateway (dev + hot reload)",
        "type": "node",
        "request": "launch",
        "cwd": "${workspaceFolder:Project Root}",
        "runtimeExecutable": "npx",
        "runtimeArgs": [
            "@dotenvx/dotenvx", "run", "--",
            "npx", "nodemon",
            "--cwd", "services/device-gateway",
            "--exec", "node -r ts-node/register",
            "--ext", "ts,json",
            "src/index.ts"
        ],
        "env": { "TS_NODE_PROJECT": "tsconfig.json", "PORT": "3004" },
        "console": "internalConsole",
        "outputCapture": "std",
        "autoAttachChildProcesses": true,
        "restart": true,
        "preLaunchTask": "prep-device-gateway",
        "skipFiles": ["<node_internals>/**"],
        "sourceMaps": true,
        "outFiles": ["${workspaceFolder:Device Gateway}/**/*.js"]
    },
    {
        "name": "Debug MQTT Service (dev + hot reload)",
        "type": "node",
        "request": "launch",
        "cwd": "${workspaceFolder:Project Root}",
        "runtimeExecutable": "npx",
        "runtimeArgs": [
            "@dotenvx/dotenvx", "run", "--",
            "npx", "nodemon",
            "--cwd", "services/mqtt-service",
            "--exec", "node -r ts-node/register",
            "--ext", "ts,json",
            "src/index.ts"
        ],
        "env": { "TS_NODE_PROJECT": "tsconfig.json", "PORT": "3005" },
        "console": "internalConsole",
        "outputCapture": "std",
        "autoAttachChildProcesses": true,
        "restart": true,
        "preLaunchTask": "prep-mqtt-service",
        "skipFiles": ["<node_internals>/**"],
        "sourceMaps": true,
        "outFiles": ["${workspaceFolder:MQTT Service}/**/*.js"]
    },
    {
        "name": "Debug Digest Service (dev + hot reload)",
        "type": "node",
        "request": "launch",
        "cwd": "${workspaceFolder:Project Root}",
        "runtimeExecutable": "npx",
        "runtimeArgs": [
            "@dotenvx/dotenvx", "run", "--",
            "npx", "nodemon",
            "--cwd", "services/digest-service",
            "--exec", "node -r ts-node/register",
            "--ext", "ts,json",
            "src/index.ts"
        ],
        "env": { "TS_NODE_PROJECT": "tsconfig.json", "PORT": "3006" },
        "console": "internalConsole",
        "outputCapture": "std",
        "autoAttachChildProcesses": true,
        "restart": true,
        "preLaunchTask": "prep-digest-service",
        "skipFiles": ["<node_internals>/**"],
        "sourceMaps": true,
        "outFiles": ["${workspaceFolder:Digest Service}/**/*.js"]
    },
    {
        "name": "Debug Socket Server (dev + hot reload)",
        "type": "node",
        "request": "launch",
        "cwd": "${workspaceFolder:Project Root}",
        "runtimeExecutable": "npx",
        "runtimeArgs": [
            "@dotenvx/dotenvx", "run", "--",
            "npx", "nodemon",
            "--cwd", "services/socket-server",
            "--exec", "node -r ts-node/register",
            "--ext", "ts,json",
            "src/index.ts"
        ],
        "env": { "TS_NODE_PROJECT": "tsconfig.json", "PORT": "3007" },
        "console": "internalConsole",
        "outputCapture": "std",
        "autoAttachChildProcesses": true,
        "restart": true,
        "preLaunchTask": "prep-socket-server",
        "skipFiles": ["<node_internals>/**"],
        "sourceMaps": true,
        "outFiles": ["${workspaceFolder:Socket Server}/**/*.js"]
    },
    {
        "name": "Debug Automation Worker (dev + hot reload)",
        "type": "node",
        "request": "launch",
        "cwd": "${workspaceFolder:Project Root}",
        "runtimeExecutable": "npx",
        "runtimeArgs": [
            "@dotenvx/dotenvx", "run", "--",
            "npx", "nodemon",
            "--cwd", "services/automation-worker",
            "--exec", "node -r ts-node/register",
            "--ext", "ts,json",
            "src/index.ts"
        ],
        "env": { "TS_NODE_PROJECT": "tsconfig.json", "PORT": "3008" },
        "console": "internalConsole",
        "outputCapture": "std",
        "autoAttachChildProcesses": true,
        "restart": true,
        "preLaunchTask": "prep-automation-worker",
        "skipFiles": ["<node_internals>/**"],
        "sourceMaps": true,
        "outFiles": ["${workspaceFolder:Automation Worker}/**/*.js"]
    },
    {
        "name": "Debug Google Home (dev + hot reload)",
        "type": "node",
        "request": "launch",
        "cwd": "${workspaceFolder:Project Root}",
        "runtimeExecutable": "npx",
        "runtimeArgs": [
            "@dotenvx/dotenvx", "run", "--",
            "npx", "nodemon",
            "--cwd", "services/google-home",
            "--exec", "node -r ts-node/register",
            "--ext", "ts,json",
            "src/index.ts"
        ],
        "env": { "TS_NODE_PROJECT": "tsconfig.json", "PORT": "3010" },
        "console": "internalConsole",
        "outputCapture": "std",
        "autoAttachChildProcesses": true,
        "restart": true,
        "preLaunchTask": "prep-google-home",
        "skipFiles": ["<node_internals>/**"],
        "sourceMaps": true,
        "outFiles": ["${workspaceFolder:Google Home}/**/*.js"]
    },
    {
        "name": "Debug OTA Manager (dev + hot reload)",
        "type": "node",
        "request": "launch",
        "cwd": "${workspaceFolder:Project Root}",
        "runtimeExecutable": "npx",
        "runtimeArgs": [
            "@dotenvx/dotenvx", "run", "--",
            "npx", "nodemon",
            "--cwd", "services/ota-manager",
            "--exec", "node",
            "--ext", "js,json",
            "index.js"
        ],
        "env": { "PORT": "3001" },
        "console": "internalConsole",
        "outputCapture": "std",
        "autoAttachChildProcesses": true,
        "restart": true,
        "preLaunchTask": "prep-ota-manager",
        "skipFiles": ["<node_internals>/**"],
        "outFiles": ["${workspaceFolder:OTA Manager}/**/*.js"]
    },
    {
        "type": "debugpy",
        "request": "launch",
        "name": "Train ML Router Model",
        "program": "${workspaceFolder:ML Router}/training/train.py",
        "cwd": "${workspaceFolder:ML Router}",
        "console": "integratedTerminal",
        "args": []
    },
    {
        "type": "platformio-debug",
        "request": "launch",
        "name": "ESP32: PIO Debug (prod)",
        "executable": "${workspaceFolder:ESP32 Firmware}/.pio/build/4d_systems_esp32s3_gen4_r8n16-prod/firmware.elf",
        "projectEnvName": "4d_systems_esp32s3_gen4_r8n16-prod",
        "projectDir": "${workspaceFolder:ESP32 Firmware}",
        "cwd": "${workspaceFolder:ESP32 Firmware}",
        "internalConsoleOptions": "openOnSessionStart"
    }
    ],    "compounds": [
    {
        "name": "Full Stack Debug (dev)",
        "configurations": ["Debug Backend (dev + hot reload)", "Debug FrontEnd (Chrome)"]
    },
    {
        "name": "Full Stack Debug (ts-node)",
        "configurations": ["Debug Backend (ts-node)", "Debug FrontEnd (Chrome)"]
    },
    {
        "name": "All Backend Services (dev)",
        "configurations": ["Debug Backend (dev + hot reload)", "Debug ML Router (dev + hot reload)", "Debug Device Gateway (dev + hot reload)", "Debug MQTT Service (dev + hot reload)", "Debug Digest Service (dev + hot reload)", "Debug Socket Server (dev + hot reload)", "Debug Automation Worker (dev + hot reload)", "Debug Google Home (dev + hot reload)", "Debug OTA Manager (dev + hot reload)"]
    }
    ]
}