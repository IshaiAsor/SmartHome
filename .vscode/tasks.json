{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-backend",
      "type": "shell",
      "command": "npx tsc -p backend/tsconfig.json",
      "group": "build",
      "presentation": {
        "reveal": "always"
      },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "kill-old-tunnel",
      "type": "shell",
      "command": "npx -y kill-port 5432",
      "presentation": {
        "reveal": "silent"
      }
    },
    {
      "label": "ssh-postgres-tunnel",
      "dependsOn": ["kill-old-tunnel"],
      "dependsOrder": "sequence",
      "type": "shell",
      "command": "ssh -L 5432:localhost:5432 ubuntu@k3sa1-ishai.duckdns.org 'sudo fuser -k 5432/tcp || true; sudo kubectl port-forward svc/postgres 5432:5432 -n my-apps'",
      "isBackground": true,
      "problemMatcher": {
        "pattern": [
          {
            "regexp": ".",
            "file": 1,
            "location": 2,
            "message": 3
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "^Forwarding from"
        }
      }
    },
    {
      "label": "pre-debug-compiled",
      "dependsOn": [
        "build-backend",
        "ssh-postgres-tunnel"
      ],
      "dependsOrder": "sequence"
    }
  ]
}