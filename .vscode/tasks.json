{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-backend",
      "type": "shell",
      "command": "npx tsc -p tsconfig.json",
      "options": {
        "cwd": "${workspaceFolder:Backend API}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always"
      },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "kill-old-tunnel",
      "type": "shell",
      "command": "npx -y kill-port 5432",
      "presentation": {
        "reveal": "silent"
      }
    },
    {
      "label": "ssh-postgres-tunnel",
      "dependsOn": ["kill-old-tunnel"],
      "dependsOrder": "sequence",
      "type": "shell",
      "command": "ssh -L 5432:localhost:5432 -i C:\\Users\\Consist\\Desktop\\k3s-infra\\k3s-a1.1.key ubuntu@k3sa1-ishai.duckdns.org 'sudo fuser -k 5432/tcp || true; sudo kubectl port-forward svc/postgres 5432:5432 -n my-apps'",
      "isBackground": true,
      "problemMatcher": {
        "pattern": [
          {
            "regexp": ".",
            "file": 1,
            "location": 2,
            "message": 3
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "^Forwarding from"
        }
      }
    },
    {
      "label": "pre-debug-compiled",
      "dependsOn": ["build-backend"],
      "dependsOrder": "sequence"
    },
    {
      "label": "serve-backoffice",
      "type": "shell",
      "command": "npm start",
      "options": {
        "cwd": "${workspaceFolder:Backoffice UI}"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "Generating browser application bundles|Compiling..."
          },
          "endsPattern": {
            "regexp": "Application bundle generation complete|Compiled successfully"
          }
        }
      }
    },
    {
      "label": "kill-backend-ports",
      "type": "shell",
      "command": "npx -y kill-port 9229 3000",
      "presentation": { "reveal": "silent" },
      "problemMatcher": []
    },
    {
      "label": "start-backend-debug",
      "dependsOn": ["kill-backend-ports"],
      "dependsOrder": "sequence",
      "type": "shell",
      "command": "npx @dotenvx/dotenvx run -- npx nodemon --cwd backend --exec \"node --inspect=9229 -r ts-node/register\" --ext ts,json index.ts",
      "options": {
        "cwd": "${workspaceFolder:Project Root}",
        "env": { "TS_NODE_PROJECT": "tsconfig.json" }
      },
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": {
        "pattern": [{ "regexp": ".", "file": 1, "location": 2, "message": 3 }],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "\\[nodemon\\]",
          "endsPattern": "Debugger listening on"
        }
      }
    },
    {
      "label": "kill-ml-router-ports",
      "type": "shell",
      "command": "npx -y kill-port 9230 3002",
      "presentation": { "reveal": "silent" },
      "problemMatcher": []
    },
    {
      "label": "build-ml-router-deps",
      "type": "shell",
      "command": "npm run build:libs",
      "options": {
        "cwd": "${workspaceFolder:Project Root}"
      },
      "presentation": { "reveal": "silent" },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "start-ml-router-debug",
      "dependsOn": ["kill-ml-router-ports", "build-ml-router-deps"],
      "dependsOrder": "sequence",
      "type": "shell",
      "command": "npx @dotenvx/dotenvx run -- npx nodemon --cwd services/ml-router --exec \"node --inspect=9230 -r ts-node/register\" --ext ts,json src/index.ts",
      "options": {
        "cwd": "${workspaceFolder:Project Root}",
        "env": { "TS_NODE_PROJECT": "tsconfig.json", "PORT": "3002" }
      },
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": {
        "pattern": [{ "regexp": ".", "file": 1, "location": 2, "message": 3 }],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "\\[nodemon\\]",
          "endsPattern": "Debugger listening on"
        }
      }
    },
    {
      "label": "kill-mqtt-service-ports",
      "type": "shell",
      "command": "npx -y kill-port 9232 3005",
      "presentation": { "reveal": "silent" },
      "problemMatcher": []
    },
    {
      "label": "start-mqtt-service-debug",
      "dependsOn": ["kill-mqtt-service-ports", "build-ml-router-deps"],
      "dependsOrder": "sequence",
      "type": "shell",
      "command": "npx @dotenvx/dotenvx run -- npx nodemon --cwd services/mqtt-service --exec \"node --inspect=9232 -r ts-node/register\" --ext ts,json src/index.ts",
      "options": {
        "cwd": "${workspaceFolder:Project Root}",
        "env": { "TS_NODE_PROJECT": "tsconfig.json", "PORT": "3005" }
      },
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": {
        "pattern": [{ "regexp": ".", "file": 1, "location": 2, "message": 3 }],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "\\[nodemon\\]",
          "endsPattern": "Debugger listening on"
        }
      }
    },
    {
      "label": "kill-device-gateway-ports",
      "type": "shell",
      "command": "npx -y kill-port 9231 3004",
      "presentation": { "reveal": "silent" },
      "problemMatcher": []
    },
    {
      "label": "start-device-gateway-debug",
      "dependsOn": ["kill-device-gateway-ports", "build-ml-router-deps"],
      "dependsOrder": "sequence",
      "type": "shell",
      "command": "npx @dotenvx/dotenvx run -- npx nodemon --cwd services/device-gateway --exec \"node --inspect=9231 -r ts-node/register\" --ext ts,json src/index.ts",
      "options": {
        "cwd": "${workspaceFolder:Project Root}",
        "env": { "TS_NODE_PROJECT": "tsconfig.json", "PORT": "3004" }
      },
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": {
        "pattern": [{ "regexp": ".", "file": 1, "location": 2, "message": 3 }],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "\\[nodemon\\]",
          "endsPattern": "Debugger listening on"
        }
      }
    },
    {
      "label": "kill-digest-service-ports",
      "type": "shell",
      "command": "npx -y kill-port 9233 3006",
      "presentation": { "reveal": "silent" },
      "problemMatcher": []
    },
    {
      "label": "start-digest-service-debug",
      "dependsOn": ["kill-digest-service-ports", "build-ml-router-deps"],
      "dependsOrder": "sequence",
      "type": "shell",
      "command": "npx @dotenvx/dotenvx run -- npx nodemon --cwd services/digest-service --exec \"node --inspect=9233 -r ts-node/register\" --ext ts,json src/index.ts",
      "options": {
        "cwd": "${workspaceFolder:Project Root}",
        "env": { "TS_NODE_PROJECT": "tsconfig.json", "PORT": "3006" }
      },
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": {
        "pattern": [{ "regexp": ".", "file": 1, "location": 2, "message": 3 }],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "\\[nodemon\\]",
          "endsPattern": "Debugger listening on"
        }
      }
    },
    {
      "type": "PlatformIO",
      "task": "Build",
      "problemMatcher": [
        "$platformio"
      ],
      "options": {
        "cwd": "${workspaceFolder:ESP32 Firmware}"
      },
      "label": "PlatformIO: Build (ESP32Code)"
    }
  ]
}
