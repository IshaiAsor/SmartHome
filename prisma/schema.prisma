// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
//
// Tables are ordered by dependency tier (0 → 6). Keep prisma/SCHEMA.md in sync
// with any change here (mermaid ERD + per-table examples).

generator client {
  provider = "prisma-client-js"
  output   = "../backend/node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ═══ Tier 0 — External catalog (Google Smart Home) ═════════════════════════════

model GoogleActionType {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(255)
  value      String   @unique @db.VarChar(255)
  created_at DateTime @default(now()) @db.Timestamp(6)

  capabilities DeviceCapability[]

  @@map("google_action_types")
}

model GoogleDeviceTrait {
  id               Int      @id @default(autoincrement())
  name             String   @db.VarChar(255)
  value            String   @unique @db.VarChar(255)
  valid_parameters Json?
  created_at       DateTime @default(now()) @db.Timestamp(6)

  capability_traits    DeviceCapabilityTrait[]
  action_defaults      UserDeviceAction[]

  @@map("google_device_traits")
}

// ═══ Tier 1 — Device & ML catalog ══════════════════════════════════════════════

model Device {
  id           Int      @id @default(autoincrement())
  type         String   @db.VarChar(255)
  version      String   @db.VarChar(255)
  default_name String   @unique @db.VarChar(255)
  created_at   DateTime @default(now()) @db.Timestamp(6)
  updated_at   DateTime @default(now()) @db.Timestamp(6)

  capabilities         DeviceCapability[]
  user_devices         UserDevice[]  @relation("CurrentDevice")
  pending_user_devices UserDevice[]  @relation("PendingDevice")

  @@unique([type, version])
  @@map("devices")
}

model DeviceCapability {
  id                        Int      @id @default(autoincrement())
  device_id                 Int
  capability_key            String   @db.VarChar(64)
  label                     String   @db.VarChar(255)
  implementation_type       String   @db.VarChar(64)
  mqtt_action_type          String   @db.VarChar(32)
  mqtt_action_name          String   @db.VarChar(64)
  min_telemetry_interval_ms Int?
  google_type_id            Int?
  created_at                DateTime @default(now()) @db.Timestamp(6)

  device              Device                  @relation(fields: [device_id], references: [id], onDelete: Cascade)
  google_type         GoogleActionType?       @relation(fields: [google_type_id], references: [id], onDelete: SetNull)
  traits              DeviceCapabilityTrait[]
  pins                DeviceCapabilityPin[]
  user_device_actions UserDeviceAction[]

  @@unique([device_id, capability_key])
  @@map("device_capabilities")
}

model DeviceCapabilityTrait {
  id              Int               @id @default(autoincrement())
  capability_id   Int
  google_trait_id Int
  is_default      Boolean           @default(false)

  capability   DeviceCapability  @relation(fields: [capability_id], references: [id], onDelete: Cascade)
  google_trait GoogleDeviceTrait @relation(fields: [google_trait_id], references: [id], onDelete: Cascade)

  @@unique([capability_id, google_trait_id])
  @@map("device_capability_traits")
}

model DeviceCapabilityPin {
  id            Int    @id @default(autoincrement())
  capability_id Int
  key           String @db.VarChar(50)
  label         String @db.VarChar(100)
  mode          String @db.VarChar(20)

  capability       DeviceCapability      @relation(fields: [capability_id], references: [id], onDelete: Cascade)
  user_action_pins UserDeviceActionPin[]

  @@unique([capability_id, key])
  @@map("device_capability_pins")
}

model MlModel {
  id           Int      @id @default(autoincrement())
  kind         String   @db.VarChar(10)
  name         String   @db.VarChar(100)
  version      String   @db.VarChar(50)
  backend      String   @db.VarChar(20)
  model_file   String?  @db.VarChar(255)
  ollama_model String?  @db.VarChar(255)
  classes      Json?
  config       Json?
  created_at   DateTime @default(now()) @db.Timestamp(6)

  pipeline_stages PipelineStage[]

  @@unique([kind, name, version])
  @@map("ml_models")
}

// ═══ Tier 2 — Identity ═════════════════════════════════════════════════════════

model User {
  id                  Int               @id @default(autoincrement())
  user_type           Int               @default(0)
  user_role           String            @default("user") @db.VarChar(50)
  user_name           String?           @unique @db.VarChar(255)
  password            String?           @db.VarChar(255)
  google_id           String?           @unique @db.VarChar(255)
  email               String            @unique @db.VarChar(255)
  full_name           String?           @db.VarChar(255)
  profile_picture_url String?
  terms_accepted_at   DateTime?         @db.Timestamptz(6)
  created_at          DateTime?         @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?         @default(now()) @db.Timestamptz(6)

  user_devices     UserDevice[]
  user_login_audit UserLoginAudit[]
  user_rules       UserRule[]
  action_groups    UserActionGroup[]
  pipelines        Pipeline[]

  @@map("users")
}

model MqttUser {
  id            Int       @id @default(autoincrement())
  username      String    @unique @db.VarChar(100)
  password_hash String    @db.VarChar(100)
  is_superuser  Boolean?  @default(false)
  created_at    DateTime? @default(now()) @db.Timestamp(6)

  @@map("mqtt_user")
}

model UserLoginAudit {
  id         Int       @id @default(autoincrement())
  user_id    Int
  login_at   DateTime? @default(now()) @db.Timestamptz(6)
  ip_address String?   @db.VarChar(100)
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_login_audit")
}

// ═══ Tier 3 — User devices & actions ═══════════════════════════════════════════

model UserDevice {
  id                       Int       @id @default(autoincrement())
  device_type_id           Int
  user_id                  Int
  mac_id                   String    @unique @db.VarChar(255)
  name                     String    @db.VarChar(255)
  online                   Boolean   @default(false)
  last_online_date         DateTime? @db.Timestamp(6)
  current_firmware_version String?   @db.VarChar(64)
  pending_device_type_id   Int?
  pending_firmware_version String?   @db.VarChar(64)
  created_at               DateTime  @default(now()) @db.Timestamp(6)
  updated_at               DateTime  @default(now()) @db.Timestamp(6)

  device              Device              @relation("CurrentDevice", fields: [device_type_id], references: [id], onDelete: Cascade)
  pending_device      Device?             @relation("PendingDevice", fields: [pending_device_type_id], references: [id], onDelete: SetNull)
  user                User                @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_device_actions UserDeviceAction[]
  rule_conditions     UserRuleCondition[]

  @@map("user_devices")
}

model UserActionGroup {
  id         Int      @id @default(autoincrement())
  user_id    Int
  name       String   @db.VarChar(255)
  sort_order Int      @default(0)
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @db.Timestamp(6)

  user    User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  actions UserDeviceAction[]

  @@unique([user_id, name])
  @@index([user_id, sort_order])
  @@map("user_action_groups")
}

model UserDeviceAction {
  id                    Int      @id @default(autoincrement())
  user_device_id        Int
  capability_id         Int
  group_id              Int?
  default_trait_id      Int?
  action_name           String   @db.VarChar(255)
  mqtt_action_name      String   @db.VarChar(64)
  current_state         String?  @db.Text
  status                String   @default("active") @db.VarChar(20)
  sort_order            Int      @default(0)
  telemetry_interval_ms Int?
  created_at            DateTime @default(now()) @db.Timestamp(6)
  updated_at            DateTime @default(now()) @db.Timestamp(6)

  user_device       UserDevice            @relation(fields: [user_device_id], references: [id], onDelete: Cascade)
  capability        DeviceCapability      @relation(fields: [capability_id], references: [id], onDelete: Cascade)
  group             UserActionGroup?      @relation(fields: [group_id], references: [id], onDelete: SetNull)
  default_trait     GoogleDeviceTrait?    @relation(fields: [default_trait_id], references: [id], onDelete: SetNull)
  pins              UserDeviceActionPin[]
  rule_actions      UserRuleAction[]
  rule_conditions   UserRuleCondition[]
  sensor_history    SensorHistory[]
  pipeline_sensors  PipelineSensor[]
  pipeline_exec     PipelineStage[]       @relation("PipelineExec")
  pipeline_triggers PipelineTrigger[]     @relation("PipelineTrig")

  @@index([user_device_id, mqtt_action_name])
  @@map("user_device_actions")
}

model UserDeviceActionPin {
  id                    Int @id @default(autoincrement())
  user_device_action_id Int
  capability_pin_id     Int
  pin_number            Int

  user_device_action UserDeviceAction    @relation(fields: [user_device_action_id], references: [id], onDelete: Cascade)
  capability_pin     DeviceCapabilityPin @relation(fields: [capability_pin_id], references: [id], onDelete: Cascade)

  @@unique([user_device_action_id, capability_pin_id])
  @@map("user_device_action_pins")
}

// ═══ Tier 4 — Automation (rules; emergencies are rules with is_emergency) ═══════

model UserRule {
  id                 Int                 @id @default(autoincrement())
  user_id            Int
  name               String              @db.VarChar(255)
  enabled            Boolean             @default(true)
  is_emergency       Boolean             @default(false)
  condition_operator String              @default("AND") @db.VarChar(3)
  cooldown_seconds   Int                 @default(60)
  last_triggered     DateTime?           @db.Timestamp(6)
  created_at         DateTime            @default(now()) @db.Timestamp(6)
  updated_at         DateTime            @default(now()) @db.Timestamp(6)

  user       User                @relation(fields: [user_id], references: [id], onDelete: Cascade)
  conditions UserRuleCondition[]
  actions    UserRuleAction[]
  events     UserRuleEvent[]

  @@map("user_rules")
}

model UserRuleCondition {
  id                    Int    @id @default(autoincrement())
  rule_id               Int
  condition_type        String @db.VarChar(20) // threshold | device_status | schedule | vlm

  // threshold: reading from a sensor action vs a value
  user_device_action_id Int?
  operator              String? @db.VarChar(5)
  threshold_value       String? @db.VarChar(100)

  // device_status: a device is online/offline
  user_device_id        Int?
  status_value          String? @db.VarChar(20)

  // schedule: time-of-day + days-of-week (0=Sun … 6=Sat)
  schedule_time         String? @db.VarChar(5)
  schedule_days         Int[]   @default([])

  rule               UserRule          @relation(fields: [rule_id], references: [id], onDelete: Cascade)
  user_device_action UserDeviceAction? @relation(fields: [user_device_action_id], references: [id], onDelete: SetNull)
  user_device        UserDevice?       @relation(fields: [user_device_id], references: [id], onDelete: SetNull)

  @@map("user_rule_conditions")
}

model UserRuleAction {
  id                    Int    @id @default(autoincrement())
  rule_id               Int
  user_device_action_id Int
  target_state          String @db.VarChar(255)
  delay_seconds         Int    @default(0)

  rule               UserRule         @relation(fields: [rule_id], references: [id], onDelete: Cascade)
  user_device_action UserDeviceAction @relation(fields: [user_device_action_id], references: [id], onDelete: Cascade)

  @@map("user_rule_actions")
}

model UserRuleEvent {
  id              Int      @id @default(autoincrement())
  rule_id         Int
  triggered_value String?  @db.VarChar(255)
  fired_at        DateTime @default(now()) @db.Timestamp(6)

  rule UserRule @relation(fields: [rule_id], references: [id], onDelete: Cascade)

  @@index([rule_id, fired_at])
  @@map("user_rule_events")
}

// ═══ Tier 5 — Pipelines (ML execution) ═════════════════════════════════════════

model Pipeline {
  id         Int      @id @default(autoincrement())
  user_id    Int
  name       String   @db.VarChar(255)
  enabled    Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @db.Timestamp(6)

  user     User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  sensors  PipelineSensor[]
  stages   PipelineStage[]
  triggers PipelineTrigger[]
  runs     PipelineRun[]

  @@map("pipelines")
}

model PipelineSensor {
  id                    Int     @id @default(autoincrement())
  pipeline_id           Int
  group_name            String  @db.VarChar(100)
  user_device_action_id Int
  min_value             String? @db.VarChar(50)
  max_value             String? @db.VarChar(50)

  pipeline           Pipeline         @relation(fields: [pipeline_id], references: [id], onDelete: Cascade)
  user_device_action UserDeviceAction @relation(fields: [user_device_action_id], references: [id], onDelete: Cascade)

  @@unique([pipeline_id, user_device_action_id])
  @@index([pipeline_id, group_name])
  @@map("pipeline_sensors")
}

model PipelineStage {
  id                            Int    @id @default(autoincrement())
  pipeline_id                   Int
  ordinal                       Int
  kind                          String @db.VarChar(20)
  ml_model_id                   Int?
  execute_user_device_action_id Int?
  config                        Json?

  pipeline       Pipeline           @relation(fields: [pipeline_id], references: [id], onDelete: Cascade)
  ml_model       MlModel?           @relation(fields: [ml_model_id], references: [id], onDelete: Restrict)
  execute_action UserDeviceAction?  @relation("PipelineExec", fields: [execute_user_device_action_id], references: [id], onDelete: SetNull)
  run_stages     PipelineRunStage[]

  @@unique([pipeline_id, ordinal])
  @@map("pipeline_stages")
}

model PipelineTrigger {
  id                    Int     @id @default(autoincrement())
  pipeline_id           Int
  trigger_type          String  @db.VarChar(20)
  user_device_action_id Int?
  operator              String? @db.VarChar(5)
  threshold_value       String? @db.VarChar(100)
  schedule_cron         String? @db.VarChar(100)
  min_interval_sec      Int?

  pipeline           Pipeline          @relation(fields: [pipeline_id], references: [id], onDelete: Cascade)
  user_device_action UserDeviceAction? @relation("PipelineTrig", fields: [user_device_action_id], references: [id], onDelete: Cascade)

  @@index([user_device_action_id])
  @@map("pipeline_triggers")
}

model PipelineRun {
  id              Int       @id @default(autoincrement())
  pipeline_id     Int
  status          String    @db.VarChar(20)
  trigger_payload Json?
  started_at      DateTime  @default(now()) @db.Timestamp(6)
  completed_at    DateTime? @db.Timestamp(6)

  pipeline Pipeline           @relation(fields: [pipeline_id], references: [id], onDelete: Cascade)
  stages   PipelineRunStage[]

  @@index([pipeline_id, started_at])
  @@map("pipeline_runs")
}

model PipelineRunStage {
  id           Int       @id @default(autoincrement())
  run_id       Int
  stage_id     Int
  status       String    @db.VarChar(20)
  input        Json?
  output       Json?
  started_at   DateTime? @db.Timestamp(6)
  completed_at DateTime? @db.Timestamp(6)

  run   PipelineRun   @relation(fields: [run_id], references: [id], onDelete: Cascade)
  stage PipelineStage @relation(fields: [stage_id], references: [id], onDelete: Cascade)

  @@unique([run_id, stage_id])
  @@map("pipeline_run_stages")
}

// ═══ Tier 6 — Telemetry ════════════════════════════════════════════════════════

model SensorHistory {
  id                    Int              @id @default(autoincrement())
  user_device_action_id Int
  value                 String           @db.Text
  recorded_at           DateTime         @default(now()) @db.Timestamp(6)
  user_device_action    UserDeviceAction @relation(fields: [user_device_action_id], references: [id], onDelete: Cascade)

  @@index([user_device_action_id, recorded_at])
  @@map("sensor_history")
}
