{
  "name": "@lattice/prisma-client",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "prisma:prepare": "node scripts/prepare-prisma.mjs",
    "prisma:generate": "npm run prisma:prepare && prisma generate --schema=prisma/schema.prisma",
    "build": "npm run prisma:generate && tsc -p tsconfig.json",
    "dev": "npm run prisma:generate && tsc -p tsconfig.json --watch"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "typescript": "^5.9.3"
  }
}
